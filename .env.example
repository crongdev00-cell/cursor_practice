# Tavily API 키 (https://tavily.com 에서 발급)
#
# 로컬 설정:
#   1. copy .env.example .env
#   2. 아래 값에 실제 API 키 입력
#   3. 로컬 서버 실행 (Python 권장):
#        python server/app.py
#      또는 Node.js:
#        npm start
#      또는 Vercel 로컬 에뮬레이터:
#        npx vercel dev
#
# Vercel 배포:
#   1. Vercel Dashboard → Project → Settings → Environment Variables
#   2. TAVILY_API_KEY, NAVER_CLIENT_ID, NAVER_CLIENT_SECRET, GEMINI_API_KEY, GEMINI_MODEL, DAPA_SERVICE_KEY 등록
# --- Tavily (뉴스 검색) ---
# https://tavily.com
TAVILY_API_KEY=tvly-your-api-key-here

# --- 네이버 검색 API ---
# https://developers.naver.com/apps/#/register
# 애플리케이션 등록 → 사용 API: 검색 선택
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# --- Google Gemini (AI 뉴스 분석) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# 사용 모델 (미설정 시 gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# --- 방위사업청 입찰공고 (공공데이터포털) ---
# https://www.data.go.kr
# API: 방위사업청_군수품조달정보 입찰공고_GW
DAPA_SERVICE_KEY=your-public-data-service-key

PORT=3000
